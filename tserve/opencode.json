{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local transformers serve (Gemma-4 E4B)",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "google/gemma-4-E4B-it": {
          "name": "gemma-4-E4B (cache test)",
          "options": {
            "max_tokens": 4096
          },
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },
  "model": "local/google/gemma-4-E4B-it"
}
